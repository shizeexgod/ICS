# Copy this file to `.env` and fill in the real values.
# NEVER commit the real `.env` file to version control.

# Supabase/Postgres async connection string, e.g.:
# postgresql+asyncpg://postgres:PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres
DATABASE_URL=ТВОЯ_СТРОКА_ПОДКЛЮЧЕНИЯ_ИЗ_SUPABASE

# Telegram bot token issued by @BotFather
TELEGRAM_BOT_TOKEN=ТОКЕН_ТВОЕГО_БОТА_ИЗ_BOTFATHER

# --- MAX messenger Bot API (https://dev.max.ru/docs-api) -------------------
# Access token from «MAX для бизнеса» → Чат-боты → Получить токен
MAX_BOT_TOKEN=
# Secret for webhook header X-Max-Bot-Api-Secret (5-256 chars: a-zA-Z0-9_-)
MAX_WEBHOOK_SECRET=ics-max-webhook-secret
# Public HTTPS base of this API (Amvera URL) — used to register POST /subscriptions
PUBLIC_BASE_URL=https://ics-bot-shizexgod.amvera.io
MAX_API_BASE=https://platform-api2.max.ru

# --- WhatsApp via Green-API (https://green-api.com/) -----------------------
# Instance id, e.g. "1101123456" (from your Green-API cabinet, without the "waInstance" prefix)
GREEN_API_INSTANCE=
# Auth token paired with the instance above
GREEN_API_TOKEN=

# --- SMS via SMS.ru (https://sms.ru/) ---------------------------------------
# api_id from your SMS.ru cabinet (Настройки -> API)
SMS_RU_API_KEY=

# App environment: local | staging | production
ENVIRONMENT=local

# Разрешённые origins для CORS (через запятую). Для продакшена укажите URL Vercel-сайта.
# Пример для продакшена (добавьте свой домен через запятую):
# CORS_ORIGINS=https://ics-system.vercel.app,https://www.icsnotify.online,https://icsnotify.online
CORS_ORIGINS=*

# --- JWT (личный кабинет на сайте) -----------------------------------------
# Сгенерируйте случайную строку: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_EXPIRE_DAYS=30

# --- Supabase REST API (для auth/templates через PostgREST) ----------------
# Project URL: Settings -> API -> Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Service role key (server-side only, never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=

# --- SMTP (email OTP) -------------------------------------------------------
# Yandex: smtp.yandex.ru, порт 465 или 587, пароль приложения из id.yandex.ru
SMTP_SERVER=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=ICSnotify@yandex.ru
SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Admin Telegram chat ids are NO LONGER configured here.
# Each company manager binds their chat via the bot:
#   /start <company_api_key>   or   paste the api_key as a plain message
# The chat id is stored in the `company_managers` table in Supabase.
# ---------------------------------------------------------------------------

# --- YooKassa (оплата Pro, 5000 ₽/мес) ------------------------------------
# Личный кабинет ЮKassa -> Настройки -> shopId и Секретный ключ
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# URL возврата после оплаты (страница сайта на Vercel)
YOOKASSA_RETURN_URL=https://your-site.vercel.app/?billing=success
