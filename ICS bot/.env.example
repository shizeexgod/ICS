# Copy this file to `.env` and fill in the real values.
# NEVER commit the real `.env` file to version control.

# Supabase/Postgres async connection string, e.g.:
# postgresql+asyncpg://postgres:PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres
DATABASE_URL=ТВОЯ_СТРОКА_ПОДКЛЮЧЕНИЯ_ИЗ_SUPABASE

# Telegram bot token issued by @BotFather
TELEGRAM_BOT_TOKEN=ТОКЕН_ТВОЕГО_БОТА_ИЗ_BOTFATHER

# --- WhatsApp via Green-API (https://green-api.com/) -----------------------
# Instance id, e.g. "1101123456" (from your Green-API cabinet, without the "waInstance" prefix)
GREEN_API_INSTANCE=
# Auth token paired with the instance above
GREEN_API_TOKEN=

# --- SMS via SMS.ru (https://sms.ru/) ---------------------------------------
# api_id from your SMS.ru cabinet (Настройки -> API)
SMS_RU_API_KEY=

# App environment: local | staging | production
ENVIRONMENT=local

# Разрешённые origins для CORS (через запятую). Для продакшена укажите URL Vercel-сайта.
# Пример: https://ics.vercel.app,https://www.your-domain.com
CORS_ORIGINS=*

# --- JWT (личный кабинет на сайте) -----------------------------------------
# Сгенерируйте случайную строку: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_EXPIRE_DAYS=30

# --- Supabase REST API (для auth/templates через PostgREST) ----------------
# Project URL: Settings -> API -> Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Service role key (server-side only, never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=

# --- SMTP (email OTP) -------------------------------------------------------
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Admin Telegram chat ids are NO LONGER configured here.
# Each company manager binds their chat via the bot:
#   /start <company_api_key>   or   paste the api_key as a plain message
# The chat id is stored in the `company_managers` table in Supabase.
# ---------------------------------------------------------------------------
